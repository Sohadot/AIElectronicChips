      "exposure_types": ["access_exposure", "technology_exposure", "evidence_exposure"],
      "suggested_artifacts": ["compute_sovereignty_brief", "chip_dependency_audit"]
    },
    {
      "id": "design_tooling_continuity",
      "prompt": "Can the required design tools, intellectual property, and specialist capability be accessed and sustained?",
