{
  "model_id": "chip_dependency_map_foundation",
  "version": "0.1.0",
  "status": "model_preview",
  "purpose": "Reveal layered dependency exposure through governed diagnostic questions.",
  "prohibited_outputs": [
    "sovereignty_score",
    "ranking",
    "unsupported_operational_claim"
  ],
  "layers": [
    "design",
    "fabrication",
    "packaging",
    "memory",
    "interconnect",
    "power_thermal",
    "controls",
    "deployment"
  ],
  "exposure_types": [
    "concentration_exposure",
    "access_exposure",
    "capacity_exposure",
    "technology_exposure",
    "operational_exposure",
    "evidence_exposure"
  ],
  "confidence_levels": [
    "high",
    "medium",
    "low",
    "insufficient"
  ],
  "artifact_outputs": [
    "compute_sovereignty_brief",
    "chip_dependency_audit",
    "infrastructure_readiness_brief",
    "premium_reference_dossier"
  ],
  "answer_options": [
    "controlled",
    "accessible",
    "constrained",
    "unknown",
    "not_applicable"
  ],
  "questions": [
    {
      "id": "design_control",
      "prompt": "Is the required design capability controlled, licensed, or dependent on external access?",
