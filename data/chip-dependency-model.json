    {
      "id": "substitution_path",
      "prompt": "Are credible substitutes available for material dependencies across the assessed layers?",
      "layers": ["design", "fabrication", "packaging", "memory", "interconnect", "power_thermal", "controls", "deployment"],
      "exposure_types": ["concentration_exposure", "access_exposure", "technology_exposure"],
      "suggested_artifacts": ["compute_sovereignty_brief", "chip_dependency_audit"]
    },
    {
      "id": "evidence_completeness",
      "prompt": "Is the evidence sufficient, current, attributable, and scoped for a governed finding?",
      "layers": ["design", "fabrication", "packaging", "memory", "interconnect", "power_thermal", "controls", "deployment"],
