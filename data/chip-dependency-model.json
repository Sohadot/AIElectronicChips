      "exposure_types": ["access_exposure", "technology_exposure", "operational_exposure"],
      "suggested_artifacts": ["chip_dependency_audit", "premium_reference_dossier"]
    },
    {
      "id": "fabrication_access",
      "prompt": "Is suitable fabrication capacity accessible under the assessment scope and time horizon?",
      "layers": ["fabrication"],
      "exposure_types": ["access_exposure", "capacity_exposure", "concentration_exposure"],
      "suggested_artifacts": ["compute_sovereignty_brief", "chip_dependency_audit"]
    },
    {
      "id": "packaging_capacity",
      "prompt": "Is the required packaging, assembly, and test capability available at the needed capacity?",
      "layers": ["packaging"],
      "exposure_types": ["capacity_exposure", "technology_exposure", "concentration_exposure"],
      "suggested_artifacts": ["chip_dependency_audit", "premium_reference_dossier"]
    },
    {
      "id": "memory_access",
      "prompt": "Is the required memory type, bandwidth, capacity, and qualification accessible?",
